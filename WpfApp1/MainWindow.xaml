<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        xmlns:views="clr-namespace:WpfApp1.Views"
        mc:Ignorable="d"
        Title="Smart File Organizer" Height="700" Width="1200"
        Background="#2B2B2B"
        WindowStartupLocation="CenterScreen"
        Closed="Window_Closed">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <StackPanel Grid.Column="0" Background="#1E1E1E" Margin="10">
            <TextBlock Text="Smart File Organizer" Foreground="#FF6B35" FontSize="14" FontWeight="Bold" Margin="0,10"/>

            <!-- Status Indicators -->
            <StackPanel Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Ellipse Width="12" Height="12" Fill="#00FF00" VerticalAlignment="Center"/>
                    <TextBlock Text="Database: Connected" Foreground="#00FF00" Margin="8,0,0,0" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Ellipse Width="12" Height="12" Fill="#FFD700" VerticalAlignment="Center"/>
                    <TextBlock Text="AI Model: Active" Foreground="#FFD700" Margin="8,0,0,0" FontSize="11"/>
                </StackPanel>
            </StackPanel>

            <!-- Navigation Buttons -->
            <Button x:Name="RuleManagementBtn" Content="Rule Management" Background="#FF6B35" Foreground="White" Margin="0,30,0,10" Padding="10" FontWeight="Bold" Height="45" Click="NavigateToRuleManagement"/>
            <Button x:Name="FileOrganizationBtn" Content="File Organization" Background="#FF6B35" Foreground="White" Margin="0,10,0,10" Padding="10" FontWeight="Bold" Height="45" Click="NavigateToFileOrganization"/>
            <Button x:Name="CloudBtn" Content="☁ Cloud Storage" Background="#FF6B35" Foreground="White" Margin="0,10,0,10" Padding="10" FontWeight="Bold" Height="45" Click="NavigateToCloud"/>
            <Button x:Name="AnalyticsBtn" Content="Analytics" Background="#FF6B35" Foreground="White" Margin="0,10,0,10" Padding="10" FontWeight="Bold" Height="45" Click="NavigateToAnalytics"/>
            <Button x:Name="SchedulerBtn" Content="Scheduler" Background="#FF6B35" Foreground="White" Margin="0,10,0,10" Padding="10" FontWeight="Bold" Height="45" Click="NavigateToScheduler"/>
            <Button x:Name="SettingsBtn" Content="Settings" Background="#FF6B35" Foreground="White" Margin="0,10,0,10" Padding="10" FontWeight="Bold" Height="45" Click="NavigateToSettings"/>
        </StackPanel>

        <!-- Main Content Area (Content Host) -->
        <Grid x:Name="ContentHost" Grid.Column="1" Background="#2B2B2B" Margin="20"/>
    </Grid>
</Window>
